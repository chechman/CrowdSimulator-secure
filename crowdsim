#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
BACKEND_DIR="$ROOT_DIR/agent-service"
FRONTEND_DIR="$ROOT_DIR/frontend"
PID_DIR="$ROOT_DIR/.pids"
BACKEND_PID="$PID_DIR/backend.pid"
FRONTEND_PID="$PID_DIR/frontend.pid"
BACKEND_LOG="$PID_DIR/backend.log"
FRONTEND_LOG="$PID_DIR/frontend.log"

mkdir -p "$PID_DIR"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log()  { echo -e "${GREEN}[crowdsim]${NC} $1"; }
warn() { echo -e "${YELLOW}[crowdsim]${NC} $1"; }
err()  { echo -e "${RED}[crowdsim]${NC} $1"; }

is_running() {
  local pidfile="$1"
  if [ -f "$pidfile" ]; then
    local pid
    pid=$(cat "$pidfile")
    if kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
    rm -f "$pidfile"
  fi
  return 1
}

kill_pid() {
  local pidfile="$1"
  local name="$2"
  if [ -f "$pidfile" ]; then
    local pid
    pid=$(cat "$pidfile")
    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null
      sleep 1
      if kill -0 "$pid" 2>/dev/null; then
        kill -9 "$pid" 2>/dev/null
      fi
      log "$name stopped (pid $pid)"
    fi
    rm -f "$pidfile"
  fi
}

cmd_setup() {
  log "Setting up CrowdSimulator..."

  # Backend
  log "Installing backend dependencies..."
  cd "$BACKEND_DIR"
  npm install

  # Python venv
  if [ ! -d "$BACKEND_DIR/.venv" ]; then
    log "Creating Python virtual environment..."
    python3 -m venv "$BACKEND_DIR/.venv"
  fi

  log "Installing Python dependencies..."
  source "$BACKEND_DIR/.venv/bin/activate"
  pip install -r requirements.txt
  deactivate

  # Frontend
  log "Installing frontend dependencies..."
  cd "$FRONTEND_DIR"
  npm install

  # .env
  if [ ! -f "$BACKEND_DIR/.env" ]; then
    cp "$BACKEND_DIR/.env.example" "$BACKEND_DIR/.env"
    warn "Created .env from template — edit $BACKEND_DIR/.env with your OpenRouter API key"
  fi

  log "Setup complete!"
}

cmd_start() {
  # Start backend
  if is_running "$BACKEND_PID"; then
    warn "Backend already running (pid $(cat "$BACKEND_PID"))"
  else
    log "Starting backend..."
    cd "$BACKEND_DIR"
    nohup npm run dev > "$BACKEND_LOG" 2>&1 &
    echo $! > "$BACKEND_PID"
    sleep 2
    if is_running "$BACKEND_PID"; then
      log "Backend started (pid $(cat "$BACKEND_PID"))"
    else
      err "Backend failed to start — check $BACKEND_LOG"
      return 1
    fi
  fi

  # Start frontend
  if is_running "$FRONTEND_PID"; then
    warn "Frontend already running (pid $(cat "$FRONTEND_PID"))"
  else
    log "Starting frontend..."
    cd "$FRONTEND_DIR"
    nohup npm run dev > "$FRONTEND_LOG" 2>&1 &
    echo $! > "$FRONTEND_PID"
    sleep 2
    if is_running "$FRONTEND_PID"; then
      log "Frontend started (pid $(cat "$FRONTEND_PID"))"
    else
      err "Frontend failed to start — check $FRONTEND_LOG"
      return 1
    fi
  fi

  echo ""
  log "CrowdSimulator is running:"
  log "  Frontend: ${BLUE}http://localhost:5173${NC}"
  log "  Backend:  ${BLUE}http://localhost:$(grep -oP 'PORT=\K\d+' "$BACKEND_DIR/.env" 2>/dev/null || echo 8000)${NC}"
}

cmd_stop() {
  kill_pid "$FRONTEND_PID" "Frontend"
  kill_pid "$BACKEND_PID" "Backend"

  # Clean up any orphaned tsx processes for this project
  pkill -f "tsx watch.*agent-service/src/server.ts" 2>/dev/null && log "Cleaned up orphaned backend processes" || true

  log "Stopped."
}

cmd_restart() {
  log "Restarting..."
  cmd_stop
  sleep 1
  cmd_start
}

cmd_status() {
  echo ""
  if is_running "$BACKEND_PID"; then
    log "Backend:  ${GREEN}running${NC} (pid $(cat "$BACKEND_PID"))"
  else
    log "Backend:  ${RED}stopped${NC}"
  fi

  if is_running "$FRONTEND_PID"; then
    log "Frontend: ${GREEN}running${NC} (pid $(cat "$FRONTEND_PID"))"
  else
    log "Frontend: ${RED}stopped${NC}"
  fi
  echo ""
}

cmd_logs() {
  local target="${1:-all}"
  if [ "$target" = "backend" ] || [ "$target" = "all" ]; then
    if [ -f "$BACKEND_LOG" ]; then
      echo -e "${BLUE}=== Backend logs ===${NC}"
      tail -50 "$BACKEND_LOG"
    fi
  fi
  if [ "$target" = "frontend" ] || [ "$target" = "all" ]; then
    if [ -f "$FRONTEND_LOG" ]; then
      echo -e "${BLUE}=== Frontend logs ===${NC}"
      tail -50 "$FRONTEND_LOG"
    fi
  fi
}

cmd_doctor() {
  echo ""
  log "Running diagnostics..."
  echo ""

  # Node
  if command -v node &>/dev/null; then
    local node_ver
    node_ver=$(node -v)
    log "Node.js:    ${GREEN}$node_ver${NC}"
  else
    err "Node.js:    ${RED}not found${NC} — install Node.js 20+"
  fi

  # npm
  if command -v npm &>/dev/null; then
    log "npm:        ${GREEN}$(npm -v)${NC}"
  else
    err "npm:        ${RED}not found${NC}"
  fi

  # Python
  if command -v python3 &>/dev/null; then
    log "Python:     ${GREEN}$(python3 --version)${NC}"
  else
    err "Python:     ${RED}not found${NC} — install Python 3.10+"
  fi

  # Venv
  if [ -d "$BACKEND_DIR/.venv" ]; then
    log "Python venv: ${GREEN}exists${NC}"
  else
    warn "Python venv: ${YELLOW}missing${NC} — run './crowdsim setup'"
  fi

  # node_modules
  if [ -d "$BACKEND_DIR/node_modules" ]; then
    log "Backend deps: ${GREEN}installed${NC}"
  else
    warn "Backend deps: ${YELLOW}missing${NC} — run './crowdsim setup'"
  fi

  if [ -d "$FRONTEND_DIR/node_modules" ]; then
    log "Frontend deps: ${GREEN}installed${NC}"
  else
    warn "Frontend deps: ${YELLOW}missing${NC} — run './crowdsim setup'"
  fi

  # .env
  if [ -f "$BACKEND_DIR/.env" ]; then
    if grep -q "OPENROUTER_API_KEY=sk-or-" "$BACKEND_DIR/.env" 2>/dev/null; then
      log ".env:        ${GREEN}configured${NC}"
    else
      warn ".env:        ${YELLOW}exists but API key may not be set${NC}"
    fi
  else
    err ".env:        ${RED}missing${NC} — run './crowdsim setup' then edit .env"
  fi

  # Port check
  local port
  port=$(grep -oP 'PORT=\K\d+' "$BACKEND_DIR/.env" 2>/dev/null || echo 8000)
  if lsof -ti:"$port" &>/dev/null; then
    log "Port $port:   ${GREEN}in use${NC} (backend running)"
  else
    log "Port $port:   available"
  fi

  if lsof -ti:5173 &>/dev/null; then
    log "Port 5173:   ${GREEN}in use${NC} (frontend running)"
  else
    log "Port 5173:   available"
  fi

  echo ""
}

# --- Main ---

case "${1:-help}" in
  setup)   cmd_setup ;;
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  logs)    cmd_logs "${2:-all}" ;;
  doctor)  cmd_doctor ;;
  *)
    echo ""
    echo "Usage: ./crowdsim <command>"
    echo ""
    echo "Commands:"
    echo "  setup     Install all dependencies (npm, pip, .env)"
    echo "  start     Start backend + frontend"
    echo "  stop      Stop all services"
    echo "  restart   Stop then start"
    echo "  status    Show running services"
    echo "  logs      Show recent logs (logs backend|frontend|all)"
    echo "  doctor    Check system requirements and config"
    echo ""
    ;;
esac
