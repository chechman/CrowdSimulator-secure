# LLM Provider: "openrouter"
CS_LLM_PROVIDER=openrouter
CS_LLM_MODEL=x-ai/grok-4.1-fast

# Web search model (via OpenRouter)
CS_SEARCH_MODEL=perplexity/sonar

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Server
PORT=8000

# Security (optional but recommended)
# API_KEY — if set, all HTTP requests and WebSocket upgrades must include header: X-API-Key: <value>
# Leave blank to disable auth (dev mode only)
API_KEY=

# ALLOWED_ORIGIN — restricts CORS to this origin only (default: http://localhost:5173)
ALLOWED_ORIGIN=http://localhost:5173
